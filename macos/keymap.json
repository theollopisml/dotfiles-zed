[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-alt-t": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-alt-t": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-alt-t": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "cmd-shift-r": "editor::Rename"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift->": "editor::MoveToEnclosingBracket"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "shift-f12": "editor::FindAllReferences",
      "ctrl-f12": "editor::GoToImplementation",
      "ctrl-shift-f12": "editor::GoToTypeDefinition",
      "alt-ctrl-f12": "editor::GoToDeclaration"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-alt-left": "workspace::ActivatePaneLeft",
      "cmd-alt-right": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-alt-left": "workspace::ActivatePaneLeft",
      "cmd-alt-right": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-alt-left": "workspace::ActivatePaneLeft",
      "cmd-alt-right": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-alt-up": "pane::ActivatePreviousItem",
      "cmd-alt-down": "pane::ActivateNextItem",
      "cmd-alt-n": "workspace::NewTerminal"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-1": [
        "pane::ActivateItem",
        0
      ],
      "ctrl-2": [
        "pane::ActivateItem",
        1
      ],
      "ctrl-3": [
        "pane::ActivateItem",
        2
      ],
      "ctrl-4": [
        "pane::ActivateItem",
        3
      ],
      "ctrl-5": [
        "pane::ActivateItem",
        4
      ],
      "ctrl-6": [
        "pane::ActivateItem",
        5
      ],
      "ctrl-7": [
        "pane::ActivateItem",
        6
      ],
      "ctrl-8": [
        "pane::ActivateItem",
        7
      ],
      "ctrl-9": "pane::ActivateLastItem"
    }
  }
]
