{
  "Main guard": {
    "prefix": "zmain",
    "body": ["if __name__ == \"__main__\":", "\t${0:pass}"],
    "description": "if __name__ == '__main__' guard"
  },
  "Dataclass": {
    "prefix": "zdc",
    "body": [
      "@dataclass",
      "class ${1:ClassName}:",
      "\t${2:field}: ${3:str}$0"
    ],
    "description": "Dataclass template"
  },
  "TYPE_CHECKING block": {
    "prefix": "ztyc",
    "body": [
      "from __future__ import annotations",
      "",
      "from typing import TYPE_CHECKING",
      "",
      "if TYPE_CHECKING:",
      "\t${0:pass}"
    ],
    "description": "TYPE_CHECKING import block"
  },
  "Matplotlib figure": {
    "prefix": "zfig",
    "body": [
      "fig, ax = plt.subplots(${1:1, 1}, figsize=(${2:10, 6}))",
      "$0"
    ],
    "description": "Matplotlib figure setup"
  },
  "Set random seed": {
    "prefix": "zseed",
    "body": [
      "random.seed(${1:42})",
      "np.random.seed(${1:42})",
      "torch.manual_seed(${1:42})",
      "if torch.cuda.is_available():",
      "\ttorch.cuda.manual_seed_all(${1:42})$0"
    ],
    "description": "Set all random seeds for reproducibility"
  },
  "Timer block": {
    "prefix": "ztimer",
    "body": [
      "import time",
      "_start = time.perf_counter()",
      "$0",
      "print(f\"Elapsed: {time.perf_counter() - _start:.3f}s\")"
    ],
    "description": "Quick perf_counter timer"
  },
  "ArgumentParser": {
    "prefix": "zarg",
    "body": [
      "parser = argparse.ArgumentParser(description=\"${1:description}\")",
      "parser.add_argument(\"${2:--arg}\", type=${3:str}, default=${4:None}, help=\"${5:help}\")",
      "args = parser.parse_args()$0"
    ],
    "description": "Argparse boilerplate"
  }
}
